# Port configuration
PORT=5000
GATEWAY_PORT=4000

# Service URLs (used by API Gateway for routing)
AUTH_SERVICE_URL=http://127.0.0.1:5001
USER_SERVICE_URL=http://127.0.0.1:5002
MEDICINE_SERVICE_URL=http://127.0.0.1:5003
SYMPTOM_SERVICE_URL=http://127.0.0.1:5004
TELEMEDICINE_SERVICE_URL=http://127.0.0.1:5005
LAB_SERVICE_URL=http://127.0.0.1:5006
CORE_SERVICE_URL=http://127.0.0.1:5000

# MongoDB Connection String (e.g. local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/caresync

# Secret key for JWT signing (Required - backend will fail to start if empty)
JWT_SECRET=your_jwt_secret_key_here
# Allowed origins for CORS (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,https://care-sync-iota.vercel.app

# Trusted proxy hops for correct client IP (req.ip). Default 1 (one proxy hop)
# suits the Vercel/Render deployment. Set to 0 when running without a proxy to
# prevent X-Forwarded-For spoofing; accepts a hop count, "true", or "false".
TRUST_PROXY=1

# --- Security Event Logging (all optional; sensible defaults applied) ---
# Failed logins from one IP within the window before a CRITICAL
# SUSPICIOUS_LOGIN_PATTERN alert is raised (default: 5)
SECURITY_FAILED_LOGIN_THRESHOLD=5
# Rolling window in minutes for the failed-login threshold above (default: 15)
SECURITY_FAILED_LOGIN_WINDOW_MIN=15
# Max milliseconds a security-log DB write/read may take before the request
# proceeds without blocking (default: 3000)
SECURITY_DB_TIMEOUT_MS=3000
# Set to "true" to also write security events to a log file. Leave false on
# serverless / read-only hosts like Vercel (default: false — console + DB only)
SECURITY_LOG_TO_FILE=false
# Directory for the security log file when SECURITY_LOG_TO_FILE=true (default: server/logs)
SECURITY_LOG_DIR=
